# Copy to .env and fill in real values before starting

# ── Panel ────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string
CONTAINER_API_TOKEN=change_this_shared_secret

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_mysql_root
MYSQL_PASSWORD=changeme_mysql

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis

# ── PowerDNS ─────────────────────────────────────────────────────────────────
PDNS_API_KEY=changeme_pdns_key

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_HOSTNAME=mail.example.com
ALLOWED_SENDER_DOMAINS=example.com

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_grafana

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
ACME_EMAIL=admin@example.com

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=UTC
