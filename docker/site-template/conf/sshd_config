# GnuKontrolR — Customer container SSH hardening
# Customer SSH is restricted to SFTP-only within their chroot.

Port 22
Protocol 2

# Host keys — ED25519 preferred (strongest), RSA as fallback
HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key

# ── Authentication ────────────────────────────────────────────────────────────
PermitRootLogin no
PasswordAuthentication no
PubkeyAuthentication yes
AuthorizedKeysFile %h/.ssh/authorized_keys
AuthenticationMethods publickey
PermitEmptyPasswords no
ChallengeResponseAuthentication no
KerberosAuthentication no
GSSAPIAuthentication no
UsePAM no

# ── Restrict allowed users ───────────────────────────────────────────────────
# www-data:           customer SFTP (chrooted, no shell)
# webuser:            domain customer SSH — real bash shell, web content access
# gnukontrolr-admin:  superadmin full-shell SSH (key injected via panel API)
AllowUsers www-data webuser gnukontrolr-admin
DenyUsers root webpanel-sys

# ── Network hardening (global — MUST be before any Match block) ──────────────
MaxAuthTries 3
MaxSessions 2
LoginGraceTime 20
ClientAliveInterval 60
ClientAliveCountMax 2
TCPKeepAlive no

# ── Features off (global) ─────────────────────────────────────────────────────
X11Forwarding no
AllowTcpForwarding no
AllowAgentForwarding no
PermitTunnel no
GatewayPorts no
PrintMotd no
PrintLastLog no
AcceptEnv LANG LC_*

# ── Ciphers & algorithms (modern only) ───────────────────────────────────────
Ciphers aes256-gcm@openssh.com,aes128-gcm@openssh.com,chacha20-poly1305@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org

# ── Logging ──────────────────────────────────────────────────────────────────
SyslogFacility AUTH
LogLevel VERBOSE

# ── Customer chroot (SFTP only) ──────────────────────────────────────────────
Match User www-data
    ChrootDirectory /var/chroot
    ForceCommand internal-sftp -d /html -l INFO
    Banner none

# ── Domain customer SSH (real shell, web content only) ───────────────────────
# webuser gets a real bash shell to run composer/wp-cli/npm.
# No TCP forwarding — they are the domain owner, not an admin.
Match User webuser
    AllowTcpForwarding no
    X11Forwarding no
    Banner none

# ── Superadmin full-shell access (MUST be last Match block) ──────────────────
# gnukontrolr-admin gets a real shell + TCP forwarding for SSH tunnels.
# Key is injected at runtime via POST /admin/ssh-key on the container API.
Match User gnukontrolr-admin
    AllowTcpForwarding yes
    X11Forwarding no
    PermitTunnel no
    GatewayPorts no
    Banner none
